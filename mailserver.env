# Documentation:
# https://docker-mailserver.github.io/docker-mailserver/latest/config/environment/

LOG_LEVEL=info
SUPERVISOR_LOGLEVEL=
PERMIT_DOCKER=none
TLS_LEVEL=modern
SPOOF_PROTECTION=1

ENABLE_SRS=1
ENABLE_OPENDKIM=1
ENABLE_OPENDMARC=1
ENABLE_POLICYD_SPF=1
ENABLE_POP3=0
ENABLE_IMAP=1

ENABLE_AMAVIS=1
ENABLE_CLAMAV=0
ENABLE_RSPAMD=0
ENABLE_DNSBL=1

ENABLE_FAIL2BAN=1
FAIL2BAN_BLOCKTYPE=drop

SSL_TYPE=manual

POSTSCREEN_ACTION=enforce
ONE_DIR=1
ACCOUNT_PROVISIONER=FILE
UPDATE_CHECK_INTERVAL=1d
ENABLE_UPDATE_CHECK=1
