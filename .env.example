# Copy this file to `.env` and replace all placeholder values before starting the stack.

# Canonical outbound hostname used for HELO, PTR and the primary certificate name.
MAIL_HOSTNAME=mail.example.com

# Primary mail domain used by docker-mailserver for postmaster defaults.
MAIL_DOMAIN=example.com

# Postmaster / admin address for status and update notifications.
POSTMASTER_ADDRESS=postmaster@example.com

# Public timezone for logs and cron-like tasks inside containers.
TZ=Europe/Berlin

# Comma-separated SAN hostnames added to the certificate request.
# Keep the canonical `MAIL_HOSTNAME` as the first/primary hostname above.
# Example: mail.example.net,mail.client-a.com,mail.client-b.com
ADDITIONAL_CERT_DOMAINS=

# Let's Encrypt account e-mail.
LETSENCRYPT_EMAIL=admin@example.com

# Cloudflare DNS challenge token actively used by scripts/certbot-renew.sh.
# Keep it only in the local `.env`, never in tracked files.
CLOUDFLARE_DNS_API_TOKEN=replace-me

# Optional ACME staging toggle for initial smoke tests.
# Set to `1` to avoid rate limits while validating DNS challenge flow.
CERTBOT_STAGING=0

# Internal Django mail admin settings.
MAILADMIN_HOST=mailadmin.example.com
MAILADMIN_ALLOWED_HOSTS=mailadmin.example.com,127.0.0.1,localhost
MAILADMIN_CSRF_TRUSTED_ORIGINS=https://mailadmin.example.com
MAILADMIN_SECRET_KEY=change-me-too
MAILADMIN_SUPERUSER_USERNAME=admin
MAILADMIN_SUPERUSER_PASSWORD=change-me
MAILADMIN_SUPERUSER_EMAIL=admin@example.com
BLOCKLIST_DB_NAME=mailblocklist
BLOCKLIST_DB_USER=mailblocklist
BLOCKLIST_DB_PASSWORD=mailblocklist-dev

# FCM push notification bridge. Keep real values only in local `.env`.
MAIL_NOTIFY_HOOK_SECRET=replace-me
DEVICE_REGISTRATION_SECRET=replace-me

# Gmail import OAuth. The full-mail scope is required for permanent source
# deletion after a message has been safely appended and committed locally.
GMAIL_IMPORT_GOOGLE_CLIENT_ID=replace-me.apps.googleusercontent.com
GMAIL_IMPORT_GOOGLE_CLIENT_SECRET=replace-me
GMAIL_IMPORT_OAUTH_REDIRECT_URI=https://mailadmin.example.com/oauth/gmail/callback
GMAIL_IMPORT_OAUTH_SCOPES=https://mail.google.com/,https://www.googleapis.com/auth/gmail.modify
GMAIL_IMPORT_SYNC_INTERVAL_SECONDS=600
GMAIL_IMPORT_SYNC_LIMIT=100
GMAIL_IMPORT_SYNC_MAX_ACCOUNTS=20
